<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<script>
gsap.registerPlugin(ScrollTrigger);

// PRELOADER
const pre=document.getElementById('preloader');
const tl=gsap.timeline({onComplete:initPage});
tl.to('#preLogo',{opacity:1,duration:1,ease:'power3.out'})
  .to('#preLine',{width:'200px',duration:.8,ease:'power2.inOut'},'-=.3')
  .to('#preBar',{width:'100%',duration:1,ease:'power2.inOut'},'-=.2')
  .to(['#preLogo','#preLine'],{opacity:0,y:-20,duration:.6,ease:'power2.in'},'+=.2')
  .to(pre,{yPercent:-100,duration:.9,ease:'power3.inOut'});

function initPage(){
  pre.style.display='none';
  gsap.to(['#navLogo','#navLinks','#navCta'],{opacity:1,y:0,duration:.8,stagger:.1,ease:'power3.out',delay:.1});
  gsap.to('#heroEyebrow span',{y:'0%',duration:.9,ease:'power3.out',delay:.2});
  gsap.to('#heroH1 .word',{y:'0%',duration:1.1,stagger:.08,ease:'power3.out',delay:.3});
  gsap.to('#heroSub',{opacity:1,y:0,duration:.9,ease:'power3.out',delay:.9});
}

// SCROLL NAV
window.addEventListener('scroll',()=>{
  document.getElementById('mainNav').classList.toggle('scrolled',scrollY>80);
});

// SCROLL REVEAL
gsap.utils.toArray('.anim-block').forEach(el=>{
  gsap.fromTo(el,{opacity:0,y:50},{opacity:1,y:0,duration:1.1,ease:'power3.out',
    scrollTrigger:{trigger:el,start:'top 88%',toggleActions:'play none none none'}
  });
});

// DRAG SCROLL
const track=document.getElementById('workTrack');
let down=false,sx,sl;
track.addEventListener('mousedown',e=>{down=true;track.classList.add('grabbing');sx=e.pageX-track.offsetLeft;sl=track.scrollLeft;});
track.addEventListener('mouseleave',()=>{down=false;track.classList.remove('grabbing');});
track.addEventListener('mouseup',()=>{down=false;track.classList.remove('grabbing');});
track.addEventListener('mousemove',e=>{if(!down)return;e.preventDefault();track.scrollLeft=sl-(e.pageX-track.offsetLeft-sx)*1.5;});
track.addEventListener('touchstart',e=>{sx=e.touches[0].pageX;sl=track.scrollLeft;},{passive:true});
track.addEventListener('touchmove',e=>{track.scrollLeft=sl-(e.touches[0].pageX-sx)*1.5;},{passive:true});

// CURSOR
const cd=document.getElementById('curDot'),cr=document.getElementById('curRing');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cd.style.left=mx+'px';cd.style.top=my+'px';});
(function t(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;cr.style.left=rx+'px';cr.style.top=ry+'px';requestAnimationFrame(t);})();
document.querySelectorAll('a,button,.work-card,.svc,.proc,.opt').forEach(el=>{
  el.addEventListener('mouseenter',()=>cr.classList.add('big'));
  el.addEventListener('mouseleave',()=>cr.classList.remove('big'));
});

// FORM → WHATSAPP
function submitForm(){
  const name=document.getElementById('cfName').value.trim();
  const email=document.getElementById('cfEmail').value.trim();
  const phone=document.getElementById('cfPhone').value.trim();
  const type=document.getElementById('cfType').value;
  const date=document.getElementById('cfDate').value.trim();
  const msg=document.getElementById('cfMsg').value.trim();
  if(!name||!email||!type){
    alert('Please fill in your name, email, and event type to continue.');
    return;
  }
  const text='Hi Framememora! \u{1F31F}\n\nI\'d like to enquire about a website for my event.\n\n*Name:* '+name+'\n*Email:* '+email+'\n*WhatsApp:* '+(phone||'Not provided')+'\n*Event Type:* '+type+'\n*Event Date:* '+(date||'Not specified')+'\n*Vision:* '+(msg||'Will share more details');
  window.open('https://wa.me/919995878853?text='+encodeURIComponent(text),'_blank');
  document.getElementById('cfForm').style.display='none';
  const s=document.getElementById('cfSuccess');
  s.style.display='block';
  gsap.from(s,{opacity:0,y:20,duration:.8,ease:'power3.out'});
}
</script>
