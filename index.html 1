<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Framememora — Frame Your Memory Forever</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet"/>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --ink:#0A0905;--ink2:#110F0A;
  --parch:#F0EBE1;--parch2:#D8D0C0;
  --gold:#B89A5E;--gold2:#D4B87A;--gold3:#8A7040;
  --line:rgba(184,154,94,0.15);--line2:rgba(240,235,225,0.08);
}
html{scroll-behavior:smooth;}
body{background:var(--ink);color:var(--parch);font-family:'Jost',sans-serif;overflow-x:hidden;cursor:none;}

/* PRELOADER */
#preloader{position:fixed;inset:0;background:var(--ink);z-index:9999;display:flex;align-items:center;justify-content:center;flex-direction:column;}
.pre-logo{font-family:'Cormorant',serif;font-size:clamp(2rem,5vw,3.5rem);font-weight:300;color:var(--parch);letter-spacing:.1em;opacity:0;}
.pre-logo span{color:var(--gold);}
.pre-line{width:0;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);margin-top:1.5rem;}
.pre-bar{position:absolute;bottom:0;left:0;height:2px;width:0;background:linear-gradient(90deg,var(--gold3),var(--gold2));}

/* CURSOR */
.cur{position:fixed;z-index:9998;pointer-events:none;mix-blend-mode:difference;}
.cur-dot{width:8px;height:8px;background:var(--parch);border-radius:50%;transform:translate(-50%,-50%);}
.cur-ring{position:fixed;z-index:9997;pointer-events:none;width:44px;height:44px;border:1px solid rgba(184,154,94,0.5);border-radius:50%;transform:translate(-50%,-50%);transition:width .4s,height .4s,border-color .4s;}
.cur-ring.big{width:72px;height:72px;border-color:rgba(184,154,94,0.8);}

/* NAV */
nav{position:fixed;top:0;left:0;width:100%;z-index:500;padding:2rem 5%;display:flex;align-items:center;justify-content:space-between;transition:background .6s;}
nav.scrolled{background:rgba(10,9,5,0.88);backdrop-filter:blur(12px);border-bottom:1px solid var(--line);}
.nav-logo{font-family:'Cormorant',serif;font-size:1.25rem;font-weight:300;color:var(--parch);text-decoration:none;letter-spacing:.08em;opacity:0;}
.nav-logo span{color:var(--gold);}
.nav-links{display:flex;gap:3rem;list-style:none;opacity:0;}
.nav-links a{font-size:.7rem;text-decoration:none;color:rgba(240,235,225,0.5);letter-spacing:.2em;text-transform:uppercase;transition:color .3s;}
.nav-links a:hover{color:var(--parch);}
.nav-cta{opacity:0;font-size:.7rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);text-decoration:none;border:1px solid rgba(184,154,94,0.4);padding:.55rem 1.4rem;transition:all .35s;}
.nav-cta:hover{background:var(--gold);color:var(--ink);border-color:var(--gold);}

/* HERO */
.hero{height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding:0 5% 7rem;position:relative;overflow:hidden;}
.hero-canvas{position:absolute;inset:0;z-index:0;}
.orb{position:absolute;border-radius:50%;filter:blur(120px);opacity:.18;animation:drift 18s ease-in-out infinite alternate;}
.orb1{width:60vw;height:60vw;background:radial-gradient(circle,#B89A5E,transparent 70%);top:-20%;left:-10%;}
.orb2{width:40vw;height:40vw;background:radial-gradient(circle,#8A7040,transparent 70%);bottom:-10%;right:-5%;animation-delay:-6s;}
.orb3{width:30vw;height:30vw;background:radial-gradient(circle,#D4B87A,transparent 70%);top:30%;right:20%;animation-delay:-12s;opacity:.08;}
@keyframes drift{from{transform:translate(0,0) scale(1);}to{transform:translate(4%,6%) scale(1.1);}}
.hero-content{position:relative;z-index:2;}
.hero-eyebrow{font-size:.68rem;letter-spacing:.28em;text-transform:uppercase;color:var(--gold);display:flex;align-items:center;gap:1.2rem;margin-bottom:2.5rem;}
.hero-eyebrow-line{width:40px;height:1px;background:var(--gold);}
.hero-eyebrow span{display:block;transform:translateY(100%);}
.hero-h1{font-family:'Cormorant',serif;font-size:clamp(4rem,11vw,10.5rem);font-weight:300;line-height:.9;color:var(--parch);}
.hero-h1 .line-wrap{overflow:hidden;display:block;}
.hero-h1 .word{display:inline-block;transform:translateY(115%);}
.hero-h1 em{font-style:italic;color:var(--gold2);}
.hero-sub-row{display:flex;align-items:flex-end;justify-content:space-between;margin-top:3.5rem;opacity:0;}
.hero-sub{font-size:.95rem;color:rgba(240,235,225,0.55);max-width:380px;line-height:1.85;font-weight:300;}
.hero-scroll-hint{display:flex;flex-direction:column;align-items:center;gap:.6rem;opacity:.4;}
.hero-scroll-hint span{font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;writing-mode:vertical-rl;}
.scroll-line{width:1px;height:50px;background:linear-gradient(to bottom,var(--parch),transparent);animation:scrollPulse 2s ease-in-out infinite;}
@keyframes scrollPulse{0%,100%{opacity:.4;}50%{opacity:.15;transform:scaleY(.6);}}

/* MARQUEE */
.marquee-wrap{padding:.9rem 0;overflow:hidden;border-top:1px solid var(--line);border-bottom:1px solid var(--line);}
.marquee-track{display:inline-flex;animation:marquee 30s linear infinite;}
.marquee-item{font-family:'Cormorant',serif;font-size:1.1rem;font-weight:300;font-style:italic;color:rgba(240,235,225,0.3);padding:0 2.8rem;display:inline-flex;align-items:center;gap:2.8rem;white-space:nowrap;}
.marquee-gem{font-size:.55rem;color:var(--gold);opacity:.7;}
@keyframes marquee{to{transform:translateX(-50%);}}

/* SHARED */
.s-label{font-size:.65rem;letter-spacing:.28em;text-transform:uppercase;color:var(--gold);display:flex;align-items:center;gap:1rem;margin-bottom:2rem;}
.s-label::before{content:'';width:30px;height:1px;background:var(--gold);}
.s-title{font-family:'Cormorant',serif;font-size:clamp(2.8rem,6vw,6rem);font-weight:300;line-height:1;color:var(--parch);}
.s-title em{font-style:italic;color:var(--gold2);}
.anim-block{opacity:0;transform:translateY(40px);}

/* INTRO */
.intro{padding:9rem 5%;border-top:1px solid var(--line2);}
.intro-inner{display:grid;grid-template-columns:1fr 1.2fr;gap:8rem;align-items:center;}
.intro-big{font-family:'Cormorant',serif;font-size:clamp(2.4rem,4.5vw,4.5rem);font-weight:300;line-height:1.1;color:var(--parch);}
.intro-big em{font-style:italic;color:var(--gold2);}
.intro-body{font-size:.95rem;color:rgba(240,235,225,0.5);line-height:2;font-weight:300;margin-bottom:2.5rem;}
.opt-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--line);}
.opt{background:var(--ink2);padding:1.8rem;transition:background .4s;}
.opt:hover{background:#1A1710;}
.opt-icon{font-family:'Cormorant',serif;font-style:italic;font-size:1.1rem;color:var(--gold);margin-bottom:.8rem;}
.opt-title{font-family:'Cormorant',serif;font-size:1.25rem;font-weight:400;color:var(--parch);margin-bottom:.5rem;}
.opt-desc{font-size:.8rem;color:rgba(240,235,225,0.4);line-height:1.7;font-weight:300;}

/* WORK */
.work-section{padding:9rem 5%;border-top:1px solid var(--line2);}
.work-header{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:5rem;}
.view-all{font-size:.68rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(240,235,225,0.4);text-decoration:none;display:flex;align-items:center;gap:.8rem;transition:color .3s;}
.view-all:hover{color:var(--gold);}
.view-all::after{content:'';width:28px;height:1px;background:currentColor;transition:width .3s;}
.view-all:hover::after{width:44px;}
.work-track-wrap{overflow-x:auto;cursor:grab;scrollbar-width:none;padding-bottom:1rem;}
.work-track-wrap::-webkit-scrollbar{display:none;}
.work-track-wrap.grabbing{cursor:grabbing;}
.work-track{display:flex;gap:1.5rem;width:max-content;}
.work-card{flex-shrink:0;position:relative;overflow:hidden;border-radius:2px;}
.work-card:nth-child(1){width:55vw;height:70vh;}
.work-card:nth-child(2){width:35vw;height:70vh;}
.work-card:nth-child(3){width:40vw;height:70vh;}
.work-card:nth-child(4){width:50vw;height:70vh;}
.wc-bg{position:absolute;inset:0;transition:transform .7s cubic-bezier(.16,1,.3,1);}
.work-card:hover .wc-bg{transform:scale(1.06);}
.wc1{background:linear-gradient(160deg,#1C1409,#2E200A,#120D05);}
.wc2{background:linear-gradient(160deg,#090A14,#0C1020,#060709);}
.wc3{background:linear-gradient(160deg,#14090F,#220E18,#0D060B);}
.wc4{background:linear-gradient(160deg,#090F09,#0C1A0C,#060A06);}
.wc-deco{position:absolute;inset:0;opacity:.12;width:100%;height:100%;}
.wc-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.9) 0%,rgba(0,0,0,.1) 60%,transparent 100%);}
.wc-info{position:absolute;bottom:0;left:0;right:0;padding:2.5rem 2rem;transform:translateY(6px);transition:transform .4s;}
.work-card:hover .wc-info{transform:none;}
.wc-tag{font-size:.6rem;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-bottom:.6rem;}
.wc-name{font-family:'Cormorant',serif;font-size:1.8rem;font-weight:300;color:var(--parch);line-height:1.1;}
.wc-sub{font-size:.75rem;color:rgba(255,255,255,.4);margin-top:.4rem;}
.wc-arrow{position:absolute;top:2rem;right:2rem;width:44px;height:44px;border:1px solid rgba(184,154,94,0.3);border-radius:50%;display:flex;align-items:center;justify-content:center;opacity:0;transform:translateY(-6px);transition:all .4s;}
.work-card:hover .wc-arrow{opacity:1;transform:none;}

/* SERVICES */
.services-section{padding:9rem 5%;border-top:1px solid var(--line2);}
.svc-grid{margin-top:5rem;display:grid;grid-template-columns:1fr 1fr;}
.svc{padding:3rem 0;border-bottom:1px solid var(--line2);position:relative;overflow:hidden;transition:padding .4s;}
.svc::before{content:'';position:absolute;left:0;bottom:0;width:0;height:1px;background:var(--gold);transition:width .6s cubic-bezier(.16,1,.3,1);}
.svc:hover::before{width:100%;}
.svc:nth-child(odd){padding-right:4rem;border-right:1px solid var(--line2);}
.svc:nth-child(even){padding-left:4rem;}
.svc-num{font-family:'Cormorant',serif;font-size:.85rem;font-style:italic;color:var(--gold3);margin-bottom:1.2rem;}
.svc-title{font-family:'Cormorant',serif;font-size:2.2rem;font-weight:300;color:var(--parch);margin-bottom:1rem;transition:color .3s;}
.svc:hover .svc-title{color:var(--gold2);}
.svc-text{font-size:.85rem;color:rgba(240,235,225,0.4);line-height:1.8;font-weight:300;max-width:360px;}

/* PROCESS */
.process-section{padding:9rem 5%;border-top:1px solid var(--line2);}
.proc{display:grid;grid-template-columns:64px 1fr 1fr;gap:3rem;padding:2.8rem 0;border-bottom:1px solid var(--line2);align-items:start;transition:background .3s;cursor:default;}
.proc:hover{background:rgba(240,235,225,.015);}
.proc-idx{font-family:'Cormorant',serif;font-style:italic;font-size:1rem;color:var(--gold3);padding-top:.2rem;}
.proc-title{font-family:'Cormorant',serif;font-size:2rem;font-weight:300;color:var(--parch);transition:color .3s;}
.proc:hover .proc-title{color:var(--gold2);}
.proc-desc{font-size:.85rem;color:rgba(240,235,225,0.4);line-height:1.85;font-weight:300;}

/* CTA BANNER */
.cta-banner{padding:12rem 5%;text-align:center;border-top:1px solid var(--line2);position:relative;overflow:hidden;}
.cta-bg-word{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:'Cormorant',serif;font-size:clamp(8rem,25vw,28rem);font-weight:600;color:transparent;-webkit-text-stroke:1px rgba(184,154,94,0.05);white-space:nowrap;pointer-events:none;user-select:none;}
.cta-tagline{font-size:.8rem;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-bottom:3rem;position:relative;z-index:1;}
.cta-title{font-family:'Cormorant',serif;font-size:clamp(3.5rem,9vw,9rem);font-weight:300;line-height:.9;color:var(--parch);margin-bottom:0;position:relative;z-index:1;}
.cta-title em{font-style:italic;color:var(--gold2);}

/* CONTACT SECTION */
.contact-section{padding:9rem 5%;border-top:1px solid var(--line2);}
.contact-inner{display:grid;grid-template-columns:1fr 1.1fr;gap:8rem;align-items:start;}
.contact-body{font-size:.95rem;color:rgba(240,235,225,0.45);line-height:2;font-weight:300;margin-top:2rem;max-width:360px;}
.reach-list{margin-top:3rem;display:flex;flex-direction:column;gap:1.2rem;}
.reach-item{display:flex;align-items:center;gap:1rem;font-size:.82rem;color:rgba(240,235,225,0.45);text-decoration:none;transition:color .3s;}
.reach-item:hover{color:var(--gold);}
.reach-icon{width:36px;height:36px;border:1px solid var(--line2);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:border-color .3s;}
.reach-item:hover .reach-icon{border-color:var(--gold);}

/* FORM */
.cf{background:var(--ink2);border:1px solid var(--line2);padding:3rem;}
.cf-row{margin-bottom:1.5rem;}
.cf-row label{display:block;font-size:.62rem;letter-spacing:.22em;text-transform:uppercase;color:var(--gold3);margin-bottom:.7rem;}
.cf-row input,.cf-row select,.cf-row textarea{width:100%;background:transparent;border:none;border-bottom:1px solid rgba(240,235,225,0.12);color:var(--parch);font-family:'Jost',sans-serif;font-size:.9rem;font-weight:300;padding:.6rem 0;outline:none;transition:border-color .3s;-webkit-appearance:none;}
.cf-row input:focus,.cf-row textarea:focus{border-bottom-color:var(--gold);}
.cf-row select{cursor:pointer;appearance:none;}
.cf-row select option{background:var(--ink2);color:var(--parch);}
.cf-row textarea{resize:none;min-height:100px;line-height:1.7;}
.cf-row input::placeholder,.cf-row textarea::placeholder{color:rgba(240,235,225,0.2);}
.cf-2col{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;}
.cf-submit{margin-top:2rem;width:100%;background:transparent;border:1px solid rgba(184,154,94,0.5);color:var(--parch);font-family:'Jost',sans-serif;font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;padding:1.1rem;cursor:pointer;transition:all .5s;position:relative;overflow:hidden;}
.cf-submit::before{content:'';position:absolute;inset:0;background:var(--gold);transform:translateX(-101%);transition:transform .5s cubic-bezier(.16,1,.3,1);}
.cf-submit:hover::before{transform:none;}
.cf-submit:hover{color:var(--ink);}
.cf-submit-text{position:relative;pointer-events:none;}
.cf-success{display:none;text-align:center;padding:2.5rem;font-family:'Cormorant',serif;font-size:1.4rem;font-weight:300;color:var(--gold2);font-style:italic;line-height:1.6;}

/* WHATSAPP FLOAT */
.wa-float{position:fixed;bottom:2.2rem;right:2.2rem;z-index:600;display:flex;align-items:center;gap:.8rem;background:#25D366;color:#fff;padding:.85rem 1.4rem .85rem 1rem;border-radius:60px;text-decoration:none;font-size:.78rem;letter-spacing:.06em;box-shadow:0 8px 30px rgba(37,211,102,0.3);transition:all .35s;overflow:hidden;}
.wa-float::before{content:'';position:absolute;inset:0;background:#1ebe5d;transform:translateX(-101%);transition:transform .4s cubic-bezier(.16,1,.3,1);}
.wa-float:hover::before{transform:none;}
.wa-float svg,.wa-float span{position:relative;z-index:1;}
.wa-float:hover{transform:translateY(-2px);box-shadow:0 12px 40px rgba(37,211,102,0.45);}

/* FOOTER */
footer{border-top:1px solid var(--line2);padding:4rem 5% 3rem;}
.footer-top{display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;gap:4rem;margin-bottom:4rem;}
.f-brand-name{font-family:'Cormorant',serif;font-size:1.5rem;font-weight:300;color:var(--parch);margin-bottom:.8rem;}
.f-brand-name span{color:var(--gold);}
.f-brand-tag{font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:rgba(240,235,225,0.3);margin-bottom:1.5rem;}
.f-brand-desc{font-size:.82rem;color:rgba(240,235,225,0.3);line-height:1.8;font-weight:300;max-width:240px;}
.f-col h5{font-size:.65rem;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-bottom:1.5rem;}
.f-col ul{list-style:none;}
.f-col li{margin-bottom:.7rem;}
.f-col a{font-size:.82rem;color:rgba(240,235,225,0.35);text-decoration:none;transition:color .3s;}
.f-col a:hover{color:var(--parch);}
.footer-bottom{border-top:1px solid var(--line2);padding-top:2rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;}
.f-copy{font-size:.7rem;color:rgba(240,235,225,0.2);letter-spacing:.08em;}
.f-made{font-size:.7rem;color:rgba(184,154,94,0.4);letter-spacing:.06em;}

/* RESPONSIVE */
@media(max-width:900px){
  nav .nav-links{display:none;}
  .intro-inner{grid-template-columns:1fr;gap:4rem;}
  .svc-grid{grid-template-columns:1fr;}
  .svc:nth-child(odd){padding-right:0;border-right:none;}
  .svc:nth-child(even){padding-left:0;}
  .proc{grid-template-columns:48px 1fr;}.proc-desc{display:none;}
  .footer-top{grid-template-columns:1fr 1fr;}
  .contact-inner{grid-template-columns:1fr;gap:4rem;}
  .cf-2col{grid-template-columns:1fr;}
  .cur,.cur-ring{display:none;}body{cursor:auto;}
}
@media(max-width:600px){
  .footer-top{grid-template-columns:1fr;}
  .work-card:nth-child(1){width:85vw;}
  .work-card:nth-child(2){width:70vw;}
  .work-card:nth-child(3){width:75vw;}
  .work-card:nth-child(4){width:80vw;}
}
</style>
</head>
